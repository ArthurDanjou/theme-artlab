{
  "publisher": "arthurdanjou",
  "name": "theme-artlab",
  "displayName": "ArtLab Theme",
  "type": "module",
  "version": "1.1.4",
  "packageManager": "bun@1.3.11",
  "description": "ArtLab theme for VS Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arthurdanjou/theme-artlab"
  },
  "bugs": {
    "url": "https://github.com/arthurdanjou/theme-artlab/issues"
  },
  "keywords": [
    "theme",
    "artlab",
    "light",
    "dark"
  ],
  "categories": [
    "Themes"
  ],
  "exports": {
    "./*": "./*"
  },
  "icon": "icon.png",
  "files": [
    "LICENSE.md",
    "icon.png",
    "vscode/*",
    "zed/*",
    "homeassistant/*"
  ],
  "engines": {
    "vscode": "^1.82.0",
    "node": ">=25.0.0"
  },
  "contributes": {
    "themes": [
      {
        "label": "ArtLab Light",
        "uiTheme": "vs",
        "path": "./vscode/artlab-light.json"
      },
      {
        "label": "ArtLab Dark",
        "uiTheme": "vs-dark",
        "path": "./vscode/artlab-dark.json"
      }
    ]
  },
  "scripts": {
    "build": "tsx scripts/index.ts",
    "dev": "tsx watch scripts/index.ts",
    "vscode:prepublish": "npm run build",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "install:themes": "tsx scripts/install.ts",
    "install:zed": "tsx scripts/install.ts zed",
    "install:ghostty": "tsx scripts/install.ts ghostty",
    "release": "bumpp --all",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.2.0",
    "@antfu/utils": "9.3.0",
    "@types/color": "4.2.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "25.6.0",
    "@vscode/vsce": "^3.9.1",
    "bumpp": "11.0.1",
    "color": "^5.0.3",
    "eslint": "10.2.1",
    "fs-extra": "^11.3.4",
    "ovsx": "^0.10.11",
    "tsup": "^8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vsxpub": "^0.1.4"
  },
  "preview": true
}
